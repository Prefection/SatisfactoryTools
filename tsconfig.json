{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"lib": ["ESNext", "DOM", "DOM.Iterable"],
		"jsx": "preserve",
		"strict": true,
		"noImplicitAny": true,
		"strictNullChecks": true,
		"resolveJsonModule": true,
		"esModuleInterop": true,
		"isolatedModules": true,
		"skipLibCheck": true,
		"noEmit": true,
		"types": ["vite/client"],
		"baseUrl": ".",
		"paths": {
			"@src/*": ["./src/*"],
			"@styles/*": ["./styles/*"],
			"@data/*": ["./data/*"],
			"@bin/*": ["./bin/*"]
		}
	},
	"include": ["src/**/*.ts", "src/**/*.vue", "vite.config.ts", "env.d.ts"]
}
